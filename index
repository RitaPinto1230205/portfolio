  footer .blob.f2{ background:var(--teal); bottom:-200px; right:-100px; }
  .footer-inner{ position:relative; z-index:1; max-width:var(--max); margin:0 auto; }
  footer h2{ font-size:clamp(2rem, 5vw, 3.2rem); font-weight:800; margin-bottom:18px; }
  footer p.lede{ color:rgba(251,241,220,0.7); max-width:480px; margin-bottom:36px; font-size:1.05rem; }
  .footer-links{ display:flex; gap:18px; flex-wrap:wrap; margin-bottom:50px; }
  .footer-links a{
    text-decoration:none; font-weight:700; font-size:0.95rem; color:var(--cream);
    border:1.5px solid rgba(251,241,220,0.3); padding:12px 22px; border-radius:999px; transition:all 0.2s ease;
  }
  .footer-links a:hover{ background:var(--cream); color:var(--ink); border-color:var(--cream); }
  .footer-bottom{ display:flex; justify-content:space-between; flex-wrap:wrap; gap:10px; font-size:0.8rem; color:rgba(251,241,220,0.45); border-top:1px solid rgba(251,241,220,0.15); padding-top:24px; }
</style>
